{
    "name": "@midnight/zkir-keygen-wasm",
    "version": "0.1.0",
    "type": "module",
    "description": "WASM keygen for zkir circuits (browser-compatible compile-many)",
    "files": [
        "pkg/"
    ],
    "scripts": {
        "build": "wasm-pack build --target web --out-dir pkg",
        "build:dev": "wasm-pack build --dev --target web --out-dir pkg",
        "test": "wasm-pack test --headless --chrome",
        "test:firefox": "wasm-pack test --headless --firefox"
    }
}
